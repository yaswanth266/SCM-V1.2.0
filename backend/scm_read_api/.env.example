# Copy to .env and fill in.

# SQLAlchemy URL to the SCM database (read-only user recommended).
# MySQL:  mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME
SCM_DATABASE_URL=mysql+pymysql://root:rolex@localhost:3306/bhspl_scm



# Optional shared secret. If set, every request must send header:  X-API-Key: <this>
# Leave blank to run without auth (fine for a trusted internal network).
SCM_API_KEY=
