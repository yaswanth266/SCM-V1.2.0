# ==============================================================================
# BHSPL SCM ERP - Backend Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and populate with your local/production credentials.
# DO NOT commit the actual '.env' file to your Git repository!

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=bhspl_scm

# JWT Secrets (generate strong random keys for production, e.g., 'openssl rand -hex 32')
JWT_SECRET_KEY=generate-a-strong-random-jwt-secret-key-for-production
JWT_REFRESH_SECRET_KEY=generate-another-strong-random-refresh-key-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App Settings
APP_NAME=BHSPL SCM ERP
APP_VERSION=1.0.0
DEBUG=False
CORS_ORIGINS=["http://localhost:5173","https://your-production-frontend.domain"]

# File Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.gif,.xlsx,.xls,.csv,.doc,.docx

# Email Configuration (Configure SMTP for notification jobs)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Rate Limiting & External Integration
RATE_LIMIT_STORAGE_URI=memory://
HR_API_KEY=your_hr_api_key_here
HR_EMPLOYEE_API_URL=http://your-hr-employee-api-endpoint/api/employees
HR_API_TIMEOUT=30
